19:["$","section",null,{"id":"otros","style":{"marginBottom":0},"children":[["$","h2",null,{"style":{"fontFamily":"var(--serif)","fontSize":"clamp(1.8rem,3vw,2.8rem)","fontWeight":300,"color":"var(--white)","marginBottom":"1.25rem"},"children":["Otros ",["$","em",null,{"style":{"fontStyle":"italic","color":"var(--rl)"},"children":"sistemas"}]]}],["$","div",null,{"style":{"display":"grid","gridTemplateColumns":"repeat(4,1fr)","gap":"1px","background":"rgba(250,249,246,.04)"},"children":[["$","$L1a","sip",{"s":{"id":"sip","idx":0,"slug":"sip","badge":"Panel sándwich · CAT N°3648","name":"Sistema SIP","desc":"OSB + EPS + OSB. Estructura, aislación y cerramiento en un elemento autoportante. El sistema de mayor performance térmica disponible en Argentina.","costo":"USD 1.300–1.600","tiempo":"4–6 semanas","aislacion":"Excelente · Rt=3","humeda":"No","pros":["Rt=3 m²°C/W — equivale a 1.26m de ladrillo","7% de infiltración de aire vs estructura convencional","Construcción 100% en seco, sin esperas de fraguado","Precisión dimensional de fábrica ±2mm","Sismorresistencia certificada CAS-INPRES","18 toneladas de carga por panel (IRAM 11585)","Fábrica TAO en Neuquén — distribución a toda Patagonia"],"cons":["Requiere proyecto minucioso antes del montaje","Instalaciones deben planificarse ANTES del emplacado","No se puede cortar horizontalmente","Requiere instaladores certificados TAO","Costo inicial mayor que steel frame en obra gris"],"specs":[["Paneles","SIP 70 (92mm) · SIP 90 (112mm) · YANE SIP 50 (69mm)"],["Resistencia térmica","Rt=2 (SIP 70) · Rt=3 (SIP 90)"],["Carga compresión","18 tn/panel · Norma IRAM 11585"],["Densidad EPS","20 kg/m³ · celdas cerradas"],["OSB exterior","11.1mm · APA Engineered Wood"],["Dimensiones std","1.22 × 2.44 m"],["Certificaciones","CAT N°3648 · CAS · ISO 9001:2015 · SIPA · APA"],["Fábrica","TAO Soluciones Constructivas · Neuquén"]],"callout":{"type":"ok","ico":"✓","title":"Dato ORNL (Oak Ridge National Laboratory)","body":"Un panel SIP de 6\" tiene R-value efectivo 96% mayor que una pared 2×6 con R-19 convencional. La diferencia no es el material: es la hermeticidad del sistema."},"certTags":["CAT N°3648","CAS · INPRES","IRAM/ISO 9001:2015","SIPA","APA Engineered Wood"],"veredicto":{"patagonia":"Altísima","autoconstruccion":"Baja — requiere instaladores certificados","errorTipico":"Improvisar instalaciones en obra o cortar el panel horizontalmente","recomendacion":"Sistema de referencia para Patagonia. La mejor relación entre tiempo, aislación y precisión. La inversión adicional vs steel frame se recupera en menor costo de calefacción en 3–5 años."}},"compact":true}],["$","$L1a","steel",{"s":{"id":"steel","idx":1,"slug":"steel-frame","badge":"Construcción en seco · CIRSOC 303","name":"Steel Frame","desc":"Estructura de perfiles de acero galvanizado con placas de cerramiento. El sistema en seco más difundido en Argentina.","costo":"USD 1.100–1.200","tiempo":"4–6 meses","aislacion":"Buena con lana mineral","humeda":"No","pros":["25–40% más rápido que mampostería","12–15% más barato que mampostería","Sin obra húmeda — sin morteros ni fraguados","Alta disponibilidad de mano de obra capacitada","Reconocido en casi todos los códigos municipales","Alta flexibilidad en diseño arquitectónico"],"cons":["Performance térmica depende de la ejecución de capas","Puente térmico en encuentros metálicos si no se resuelve","Precio sensible al costo del acero importado","No llega a la hermeticidad del SIP sin trabajo adicional"],"specs":[["Perfil base","Acero galvanizado G90 (275 g/m²)"],["Espaciado montantes","40–60 cm c/c según cálculo"],["Cerramiento exterior","OSB + cementicia + EIFS/siding"],["Cerramiento interior","Placa de yeso (Durlock o similar)"],["Aislación","Lana de vidrio o mineral entre montantes"],["Tiempo obra 100m²","4–6 meses"],["Normativa","CIRSOC 303"],["Mano de obra","30–40% del costo total"]],"callout":{"type":"info","ico":"ℹ","title":"Puente térmico en Patagonia","body":"Los perfiles metálicos transmiten temperatura. Con rotura de puente térmico correcta, la diferencia con SIP se reduce. Sin esa solución, el diferencial es significativo a −15°C."},"certTags":["CIRSOC 303","Norma IRAM 11561"],"veredicto":{"patagonia":"Alta — con buen diseño térmico","autoconstruccion":"Media — más difundido, más fácil de conseguir ejecutores","errorTipico":"No resolver el puente térmico en encuentros de montantes con estructura","recomendacion":"Sistema sólido y muy práctico. Si el presupuesto no alcanza para SIP, el Steel Frame bien ejecutado con lana mineral densa es la alternativa válida para Patagonia."}},"compact":true}],"$L1b","$L1c"]}]]}]
1b:["$","$L1a","madera",{"s":{"id":"madera","idx":2,"slug":"madera","badge":"Entramado · Poste y viga · CLT","name":"Madera","desc":"Cuatro variantes: platform frame, balloon frame, poste y viga, y CLT. Excelente aislación y alto valor estético.","costo":"USD 1.300–2.500","tiempo":"6–16 semanas","aislacion":"Excelente","humeda":"Mínima","pros":["Excelente aislación térmica y acústica","Reducción hasta 60% del tiempo vs mampostería","Bajo impacto ambiental — carbono capturado","Alta adopción en desarrollos turísticos patagónicos","CLT permite grandes luces y múltiples pisos","Estética cálida y muy valorada en mercado premium"],"cons":["Costo elevado por variabilidad del tipo de cambio","Disponibilidad concentrada en ciertas regiones","Requiere madera seca (<19% humedad)","Mantenimiento exterior cada 5–10 años","CIRSOC 601 no uniformemente adoptado en municipios"],"specs":[["Platform Frame","Entramado ligero estándar · 2\"×4\" o 2\"×6\""],["Balloon Frame","Montantes continuos en 2 pisos"],["Poste y Viga","Madera laminada · Grandes luces"],["CLT","Madera contralaminada · Escala media-grande"],["Humedad máxima","<19% para evitar deformaciones"],["Normativa","CIRSOC 601"]],"callout":{"type":"warn","ico":"⚠","title":"Variable de disponibilidad","body":"La madera estructural de calidad varía por zona. En Patagonia hay buena oferta de pino. El costo final depende mucho de la especie, el origen y la distancia al proveedor."},"certTags":["CIRSOC 601","FSC Certificado","INTI · algunos fabricantes"],"veredicto":{"patagonia":"Alta — especialmente en desarrollos turísticos","autoconstruccion":"Media","errorTipico":"Usar madera verde o sin tratamiento — genera deformaciones y patologías a largo plazo","recomendacion":"Excelente para proyectos turísticos y residenciales premium en zonas de montaña. La combinación madera + SIP es el sistema más completo que hemos ejecutado."}},"compact":true}]
1c:["$","$L1a","mamp",{"s":{"id":"mamp","idx":3,"slug":"mamposteria","badge":"Sistema húmedo · CIRSOC 201","name":"Mampostería tradicional","desc":"Ladrillo + hormigón armado. El sistema de referencia histórico. Alta disponibilidad de mano de obra, baja eficiencia térmica.","costo":"USD 1.350–1.600","tiempo":"8–12 meses","aislacion":"Deficiente sin mejora","humeda":"Sí","pros":["Alta disponibilidad de mano de obra en todo el país","Facilidad para modificaciones y ampliaciones futuras","Percepción de solidez muy arraigada en el mercado","Sin restricciones normativas en ningún municipio"],"cons":["Tiempo de obra 8–12 meses para 100m²","Aislación térmica muy deficiente sin mejoras adicionales","Dependencia de obra húmeda — no funciona bien en invierno","Mayor desperdicio de materiales","Mano de obra es 60–70% del costo total"],"specs":[["Ladrillo base","Ladrillo hueco 18×18×33 cm"],["Estructura","Hormigón armado H-17 · vigas y columnas"],["Aislación","Solo con doble muro + cámara rellena"],["Revoque","3 capas: grueso, fino, enlucido o yeso"],["Tiempo obra 100m²","8–12 meses"],["Mano de obra","60–70% del costo total"],["Normativa","CIRSOC 201 · CIRSOC 102"]],"callout":{"type":"crit","ico":"⛔","title":"Aislación en Patagonia","body":"Un muro de ladrillo simple tiene Rt=0.5 m²°C/W. El SIP 90 tiene Rt=3. Para cumplir con requisitos mínimos en clima patagónico, la mampostería necesita mejoras sustanciales."},"certTags":["CIRSOC 201","CIRSOC 102","IRAM normas específicas"],"veredicto":{"patagonia":"Baja sin mejoras térmicas","autoconstruccion":"Alta — la más accesible","errorTipico":"No resolver la aislación y confiar en que \"el ladrillo es sólido\" — en Patagonia el costo operativo destruye cualquier ahorro inicial","recomendacion":"Válido donde el presupuesto no permite industrializar. Pero en Patagonia, sin mejoras térmicas significativas, no es la decisión correcta."}},"compact":true}]
