17:["$","$L16","modular",{"s":{"id":"modular","idx":6,"slug":"modular","badge":"Prefabricación 3D · Taller","name":"Modular industrializado","desc":"Módulos volumétricos fabricados íntegramente en planta y montados en sitio. Máximo grado de industrialización.","costo":"USD 1.200–1.500","tiempo":"60–90 días","aislacion":"Configurable","humeda":"No","pros":["Máximo control de calidad en fábrica","60–90 días desde inicio hasta entrega","Escalabilidad — el proceso se puede replicar","Referencia nacional: edificio modular 6 pisos en Añelo, 2024"],"cons":["Disponibilidad concentrada en Buenos Aires y Rosario","Transporte complejo para módulos grandes","Mercado joven: pocas empresas con track record sólido","Logística costosa en zonas remotas de Patagonia"],"specs":[["Proceso","Estructura 3D acero + cerramientos en planta"],["Tiempo fabricación","30–60 días en planta"],["Tiempo montaje","4–14 días en obra"],["Escalabilidad","Hasta 6+ pisos"],["Referencia AR","Edificio Añelo, Neuquén · 2024"],["Disponibilidad Patagonia","Baja–media"]],"callout":{"type":"ok","ico":"✓","title":"Caso de referencia nacional","body":"El primer edificio modular de 6 pisos en Argentina se construyó en Añelo, Neuquén en 2024. Fabricado en 4 meses, montado en 28 días. Referencia directa en contexto patagónico."},"certTags":["Variable · según fabricante","IRAM normas de acero"],"veredicto":{"patagonia":"Baja — logística limitante","autoconstruccion":"Nula","errorTipico":"Elegirlo sin verificar disponibilidad de transporte y montaje en la zona del proyecto","recomendacion":"Con mucho potencial para escala comercial y proyectos de mayor volumen. Para vivienda individual en Patagonia, la logística lo hace difícil hoy."}}}]
