18:["$","$L17","mamp",{"s":{"id":"mamp","idx":3,"slug":"mamposteria","badge":"Sistema húmedo · CIRSOC 201","name":"Mampostería tradicional","desc":"Ladrillo + hormigón armado. El sistema de referencia histórico. Alta disponibilidad de mano de obra, baja eficiencia térmica.","costo":"USD 1.350–1.600","tiempo":"8–12 meses","aislacion":"Deficiente sin mejora","humeda":"Sí","pros":["Alta disponibilidad de mano de obra en todo el país","Facilidad para modificaciones y ampliaciones futuras","Percepción de solidez muy arraigada en el mercado","Sin restricciones normativas en ningún municipio"],"cons":["Tiempo de obra 8–12 meses para 100m²","Aislación térmica muy deficiente sin mejoras adicionales","Dependencia de obra húmeda — no funciona bien en invierno","Mayor desperdicio de materiales","Mano de obra es 60–70% del costo total"],"specs":[["Ladrillo base","Ladrillo hueco 18×18×33 cm"],["Estructura","Hormigón armado H-17 · vigas y columnas"],["Aislación","Solo con doble muro + cámara rellena"],["Revoque","3 capas: grueso, fino, enlucido o yeso"],["Tiempo obra 100m²","8–12 meses"],["Mano de obra","60–70% del costo total"],["Normativa","CIRSOC 201 · CIRSOC 102"]],"callout":{"type":"crit","ico":"⛔","title":"Aislación en Patagonia","body":"Un muro de ladrillo simple tiene Rt=0.5 m²°C/W. El SIP 90 tiene Rt=3. Para cumplir con requisitos mínimos en clima patagónico, la mampostería necesita mejoras sustanciales."},"certTags":["CIRSOC 201","CIRSOC 102","IRAM normas específicas"],"veredicto":{"patagonia":"Baja sin mejoras térmicas","autoconstruccion":"Alta — la más accesible","errorTipico":"No resolver la aislación y confiar en que \"el ladrillo es sólido\" — en Patagonia el costo operativo destruye cualquier ahorro inicial","recomendacion":"Válido donde el presupuesto no permite industrializar. Pero en Patagonia, sin mejoras térmicas significativas, no es la decisión correcta."}}}]
