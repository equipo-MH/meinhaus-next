17:["$","$L16","madera",{"s":{"id":"madera","idx":2,"slug":"madera","badge":"Entramado · Poste y viga · CLT","name":"Madera","desc":"Cuatro variantes: platform frame, balloon frame, poste y viga, y CLT. Excelente aislación y alto valor estético.","costo":"USD 1.300–2.500","tiempo":"6–16 semanas","aislacion":"Excelente","humeda":"Mínima","pros":["Excelente aislación térmica y acústica","Reducción hasta 60% del tiempo vs mampostería","Bajo impacto ambiental — carbono capturado","Alta adopción en desarrollos turísticos patagónicos","CLT permite grandes luces y múltiples pisos","Estética cálida y muy valorada en mercado premium"],"cons":["Costo elevado por variabilidad del tipo de cambio","Disponibilidad concentrada en ciertas regiones","Requiere madera seca (<19% humedad)","Mantenimiento exterior cada 5–10 años","CIRSOC 601 no uniformemente adoptado en municipios"],"specs":[["Platform Frame","Entramado ligero estándar · 2\"×4\" o 2\"×6\""],["Balloon Frame","Montantes continuos en 2 pisos"],["Poste y Viga","Madera laminada · Grandes luces"],["CLT","Madera contralaminada · Escala media-grande"],["Humedad máxima","<19% para evitar deformaciones"],["Normativa","CIRSOC 601"]],"callout":{"type":"warn","ico":"⚠","title":"Variable de disponibilidad","body":"La madera estructural de calidad varía por zona. En Patagonia hay buena oferta de pino. El costo final depende mucho de la especie, el origen y la distancia al proveedor."},"certTags":["CIRSOC 601","FSC Certificado","INTI · algunos fabricantes"],"veredicto":{"patagonia":"Alta — especialmente en desarrollos turísticos","autoconstruccion":"Media","errorTipico":"Usar madera verde o sin tratamiento — genera deformaciones y patologías a largo plazo","recomendacion":"Excelente para proyectos turísticos y residenciales premium en zonas de montaña. La combinación madera + SIP es el sistema más completo que hemos ejecutado."}}}]
18:["$","$L16","modular",{"s":{"id":"modular","idx":6,"slug":"modular","badge":"Prefabricación 3D · Taller","name":"Modular industrializado","desc":"Módulos volumétricos fabricados íntegramente en planta y montados en sitio. Máximo grado de industrialización.","costo":"USD 1.200–1.500","tiempo":"60–90 días","aislacion":"Configurable","humeda":"No","pros":["Máximo control de calidad en fábrica","60–90 días desde inicio hasta entrega","Escalabilidad — el proceso se puede replicar","Referencia nacional: edificio modular 6 pisos en Añelo, 2024"],"cons":["Disponibilidad concentrada en Buenos Aires y Rosario","Transporte complejo para módulos grandes","Mercado joven: pocas empresas con track record sólido","Logística costosa en zonas remotas de Patagonia"],"specs":[["Proceso","Estructura 3D acero + cerramientos en planta"],["Tiempo fabricación","30–60 días en planta"],["Tiempo montaje","4–14 días en obra"],["Escalabilidad","Hasta 6+ pisos"],["Referencia AR","Edificio Añelo, Neuquén · 2024"],["Disponibilidad Patagonia","Baja–media"]],"callout":{"type":"ok","ico":"✓","title":"Caso de referencia nacional","body":"El primer edificio modular de 6 pisos en Argentina se construyó en Añelo, Neuquén en 2024. Fabricado en 4 meses, montado en 28 días. Referencia directa en contexto patagónico."},"certTags":["Variable · según fabricante","IRAM normas de acero"],"veredicto":{"patagonia":"Baja — logística limitante","autoconstruccion":"Nula","errorTipico":"Elegirlo sin verificar disponibilidad de transporte y montaje en la zona del proyecto","recomendacion":"Con mucho potencial para escala comercial y proyectos de mayor volumen. Para vivienda individual en Patagonia, la logística lo hace difícil hoy."}}}]
